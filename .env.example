OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Redis 连接（可选）：
# - 开发模式：取消注释并启动 docker compose up -d 后填写
# - 桌面模式：保持空值即可，会自动降级到本地 KV 文件存储（src/data/runtime_kv.json
#   或 KNOWLEDGE_MAP_DATA_DIR 指向目录下的 runtime_kv.json）
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

OCR_ENABLED=true
OCR_MIN_TEXT_LENGTH=500
TESSERACT_CMD=

PDF_PARSER_BACKEND=auto
MINERU_CLI_COMMAND=mineru
MINERU_METHOD=auto
MINERU_BACKEND=pipeline
MINERU_EFFORT=medium
MINERU_LANG=ch
MINERU_API_URL=
MINERU_API_BASE_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_API_TIMEOUT=600
PAPER_SEARCH_MAX_CANDIDATES=5
PAPER_METADATA_TEXT_EXCERPT_CHARS=8000
# 注意：
# 1. MINERU_API_URL / MINERU_API_BASE_URL 必须是 http:// 或 https:// 开头的服务地址
# 2. MINERU_API_TOKEN 才是 Bearer Token，不要把 token 填到 URL 字段里
